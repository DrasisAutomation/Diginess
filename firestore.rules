rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Stocks Collection
    // - Anyone can read so stock displays correctly on the shop frontend
    // - Authenticated users (customers at checkout & admin in POS terminal) can write/update stock
    match /stocks/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders Collection
    // - Authenticated users can create orders (checkout)
    // - Authenticated operators / admin can read and update all orders
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }

    // Users Collection
    // - Authenticated users can read and write their own documents (for spin credits, spending, etc.)
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Carts Collection
    // - Authenticated users can read and write their own cart documents
    match /carts/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
